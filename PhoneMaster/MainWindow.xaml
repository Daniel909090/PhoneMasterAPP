<Window x:Class="PhoneMaster.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhoneMaster"
        Height="600"
        Width="900"
        Icon="\Assets\favicon.ico"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <!-- WELCOME SCREEN -->
        <Grid x:Name="WelcomePanel" Visibility="Visible">

            <Grid.Background>
                <ImageBrush ImageSource="/Assets/logo.png"
                    Stretch="Uniform"/>
            </Grid.Background>

            <Border Background="#88000000">


                <Button Content="ENTER"
                        VerticalAlignment="Top"
                   Width="120"
                   Height="50"
                     
                    Click="StartButton_Click" 
                        Margin="390,467,390,0" 
                       
                        FontWeight="Bold" Background="#FFB0E7B3" Opacity="0.9" BorderBrush="#FFEE0C0C"/>

            </Border>



        </Grid>

        <!-- MAIN MENU -->
        <Grid x:Name="MenuPanel" Visibility="Collapsed">

            <StackPanel HorizontalAlignment="Center"
                        Background= "#66000000"
                        VerticalAlignment="Center"
                        Width="300">

                <TextBlock Text="PhoneMASTER"
                           FontSize="26"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <Button Content="Phones and Plans"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="Phones_Click"/>

                <Button Content="Create Order"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="CreateOrder_Click"/>

                <Button Content="Process Order"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="ProcessOrder_Click"/>

                <Button Content="Update Inventory"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="Inventory_Click"/>

                <Button Content="View Transactions"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="Transactions_Click"/>
            </StackPanel>
        </Grid>

        <!-- 1. VIEW PHONES PANEL -->
        <Grid x:Name="PhonesPanel" Visibility="Collapsed" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Phones and Plans"
               FontSize="24"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.3*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE -->
                <Grid Grid.Column="0" Margin="0,0,15,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                   
                    <!-- Search area -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="Search manufacturer or model"
                           Margin="0,0,0,5"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="SearchBox"
                             Width="240"
                             Height="30"
                             Margin="0,0,10,0"
                             KeyDown="SearchBox_KeyDown"/>

                            <Button Content="Search"
                            Width="125"
                            Height="30"
                            Margin="0,0,10,0"
                            Click="SearchPhone_Click"/>

                            <Button Content="Show All"
                            Width="125"
                            Height="30"
                            Click="ShowAllPhones_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Phones grid -->
                    <DataGrid x:Name="PhonesGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionChanged="PhonesGrid_SelectionChanged"
                              Margin="0,0,0,10">    

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="FontWeight" Value="Normal"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E6F2FF"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Phone ID"
                            Binding="{Binding PhoneID}"
                            Width="60"/>

                            <DataGridTextColumn Header="Manufacturer"
                            Binding="{Binding Manufacturer}"
                            Width="1.4*"/>

                            <DataGridTextColumn Header="Model"
                            Binding="{Binding Model}"
                            Width="2*"/>

                            <DataGridTextColumn Header="Storage"
                            Binding="{Binding Storage, StringFormat={}{0} GB}"
                            Width="60"/>

                            <DataGridTextColumn Header="Release Year"
                            Binding="{Binding ReleaseYear}"
                            Width="75"/>

                            <DataGridTextColumn Header="Price"
                            Binding="{Binding Price, StringFormat=£{0:F0}}"
                            Width="60"/>

                            <DataGridTextColumn Header="Stock"
                            Binding="{Binding Stock}"
                            Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Back button -->
                    <Button Grid.Row="2"
                    Content="Back"
                    Width="100"
                    Height="30"
                    HorizontalAlignment="Left"
                    Click="BackToMenu_Click"/>
                </Grid>

                <!-- RIGHT SIDE -->
                <Border Grid.Column="1"
                BorderBrush="Gray"
                BorderThickness="1"
                Padding="10">
                    <StackPanel>
                        <TextBlock Text="Selected Phone"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                        <Border BorderBrush="LightGray"
                        BorderThickness="1"
                        Height="260"
                        Margin="0,0,0,10">
                            <Image x:Name="SelectedPhoneImage"
                           Stretch="Uniform"/>
                        </Border>

                        <TextBlock x:Name="SelectedPhoneText"
                           Text="No phone selected"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15"/>

                        <TextBlock Text="Plans"
                           FontWeight="Bold"
                           Margin="0,10,0,5"/>

                        <TextBlock Text="Standard (£10/month)"
                           Margin="0,0,0,3"/>

                        <TextBlock Text="Premium (£20/month)"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- 2. CREATE ORDER PANEL -->
        <Grid x:Name="CreateOrderPanel" Visibility="Collapsed" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Create Order"
               FontSize="24"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

            <!-- Search bar -->
            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                <TextBlock Text="Search manufacturer or model"
                   Margin="0,0,0,5"/>

                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="CreateOrderSearchBox"
                     Width="240"
                     Height="30"
                     Margin="0,0,10,0"
                     KeyDown="CreateOrderSearchBox_KeyDown"/>

                    <Button Content="Search"
                    Width="125"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="SearchCreateOrder_Click"/>

                    <Button Content="Show All"
                    Width="125"
                    Height="30"
                    Click="ShowAllCreateOrder_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- Main content -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Phones grid -->
                <DataGrid x:Name="CreateOrderPhonesGrid"
                  Grid.Column="0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionChanged="OrderInputChanged"
                  Margin="0,0,10,0">

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="FontWeight" Value="Normal"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#E6F2FF"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Phone ID"
                                    Binding="{Binding PhoneID}"
                                    Width="60"/>

                        <DataGridTextColumn Header="Manufacturer"
                                    Binding="{Binding Manufacturer}"
                                    Width="1.4*"/>

                        <DataGridTextColumn Header="Model"
                                    Binding="{Binding Model}"
                                    Width="2.2*"/>

                        <DataGridTextColumn Header="Storage"
                                    Binding="{Binding Storage, StringFormat={}{0} GB}"
                                    Width="60"/>

                        <DataGridTextColumn Header="Release Year"
                                    Binding="{Binding ReleaseYear}"
                                    Width="75"/>

                        <DataGridTextColumn Header="Price"
                                    Binding="{Binding Price, StringFormat=£{0:F0}}"
                                    Width="60"/>

                        <DataGridTextColumn Header="Stock"
                                    Binding="{Binding Stock}"
                                    Width="50"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- RIGHT: Order details -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Quantity"/>
                    <TextBox x:Name="QuantityTextBox"
                     Margin="0,0,0,10"
                     TextChanged="OrderInputChanged"
                     MaxLength="3"
                     PreviewTextInput="NumbersOnly"/>

                    <TextBlock Text="Client Type"/>
                    <ComboBox x:Name="ClientTypeBox"
                      Margin="0,0,0,10"
                      SelectionChanged="ClientTypeBox_SelectionChanged">
                        <ComboBoxItem Content="Customer"/>
                        <ComboBoxItem Content="Company"/>
                    </ComboBox>

                    <TextBlock Text="Contract Type"/>
                    <ComboBox x:Name="ContractTypeBox"
                      Margin="0,0,0,10"
                      SelectionChanged="ContractTypeBox_SelectionChanged">
                        <ComboBoxItem Content="SIM-Free"/>
                        <ComboBoxItem Content="Phone + SIM Package"/>
                        <ComboBoxItem Content="Hire Contract"/>
                    </ComboBox>

                    <TextBlock x:Name="PlanTypeLabel"
                       Text="Plan Type"
                       Visibility="Collapsed"/>
                    <ComboBox x:Name="PlanTypeBox"
                      Margin="0,0,0,10"
                      Visibility="Collapsed"
                      SelectionChanged="OrderInputChanged">
                        <ComboBoxItem Content="Standard"/>
                        <ComboBoxItem Content="Premium"/>
                    </ComboBox>

                    <TextBlock x:Name="DurationLabel"
                       Text="Duration"
                       Visibility="Collapsed"/>
                    <ComboBox x:Name="DurationBox"
                      Margin="0,0,0,20"
                      Visibility="Collapsed"
                      SelectionChanged="OrderInputChanged"/>

                    <!-- Order Summary -->
                    <Border BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10"
                    Height="148">
                        <StackPanel>
                            <TextBlock Text="Phone Details:"
                               FontWeight="SemiBold"/>

                            <TextBlock x:Name="PhoneDetailsText"
                               Text="-"
                               Margin="0,0,0,10"/>

                            <TextBlock Text="Total Price:"
                               FontWeight="SemiBold"/>

                            <TextBlock x:Name="TotalPriceText"
                               Text="£0.00"
                               Margin="0,0,0,8"/>

                            <TextBlock Text="Monthly Cost:"
                               FontWeight="SemiBold"/>

                            <TextBlock x:Name="MonthlyCostText"
                               Text="£0.00"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Bottom buttons -->
            <Grid Grid.Row="3" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                Content="Back"
                Width="100"
                Height="35"
                HorizontalAlignment="Left"
                Click="BackFromCreateOrder_Click"/>

                <Button Grid.Column="1"
                Content="Continue"
                Width="120"
                Height="35"
                HorizontalAlignment="Right"
                Click="ContinueOrder_Click"/>
            </Grid>
        </Grid>
        
        
        
        <!-- 3. PROCESS ORDER PANEL -->
        <Grid x:Name="ProcessOrdersPanel" Visibility="Collapsed" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Process Orders"
               FontSize="24"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE: Pending Orders -->
                <Grid Grid.Column="0" Margin="0,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Pending orders list -->
                    <DataGrid x:Name="PendingOrdersGrid"
                      Grid.Row="0"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="PendingOrdersGrid_SelectionChanged"
                      Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="*"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding PhoneName}" Width="2*"/>
                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="60"/>
                            <DataGridTextColumn Header="Contract" Binding="{Binding ContractType}" Width="150"/>
                            <DataGridTextColumn Header="Total Price" Binding="{Binding TotalPrice, StringFormat=£{0:F2}}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Selected order summary -->
                    <Border Grid.Row="1"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Selected Order Summary"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                            <TextBlock x:Name="ProcessSummaryText"
                               Text="Select an order to view details."
                               TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- RIGHT SIDE: Processing Panel -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Discount Section -->
                        <Border BorderBrush="Gray"
                        BorderThickness="1"
                        Padding="10"
                        Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Discount Approval"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="Apply Discount:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,5"/>

                                    <ComboBox x:Name="ApplyDiscountBox"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      SelectionChanged="ApplyDiscountBox_SelectionChanged"
                                      Margin="0,0,0,5">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>

                                    <TextBlock x:Name="ManagerUsernameLabel"
                                       Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Manager Username:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,5"
                                       Visibility="Collapsed"/>

                                    <TextBox x:Name="ManagerUsernameBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,0,0,5"
                                     Visibility="Collapsed"/>

                                    <TextBlock x:Name="ManagerPasswordLabel"
                                       Grid.Row="2"
                                       Grid.Column="0"
                                       Text="Manager Password:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,5"
                                       Visibility="Collapsed"/>

                                    <PasswordBox x:Name="ManagerPasswordBox"
                                         Grid.Row="2"
                                         Grid.Column="1"
                                         Margin="0,0,0,5"
                                         Visibility="Collapsed"/>

                                    <TextBlock x:Name="DiscountPercentLabel"
                                       Grid.Row="3"
                                       Grid.Column="0"
                                       Text="Discount %:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Visibility="Collapsed"/>

                                    <TextBox x:Name="DiscountPercentBox"
                                     Grid.Row="3"
                                     Grid.Column="1"
                                     TextChanged="DiscountPercentBox_TextChanged"
                                     Visibility="Collapsed"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Payment Section -->
                        <Border BorderBrush="Gray"
        BorderThickness="1"
        Padding="10"
        Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Payment Details"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       Text="Payment Method:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,5"/>

                                    <ComboBox x:Name="PaymentMethodBox"
                      Grid.Row="0"
                      Grid.Column="1"
                      SelectionChanged="PaymentMethodBox_SelectionChanged"
                      Margin="0,0,0,5">
                                        <ComboBoxItem Content="CASH"/>
                                        <ComboBoxItem Content="CARD"/>
                                    </ComboBox>

                                    <TextBlock x:Name="SortCodeLabel"
                       Grid.Row="1"
                       Grid.Column="0"
                       Text="Sort Code:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,5"
                       Visibility="Collapsed"/>

                                    <TextBox x:Name="SortCodeBox"
                     Grid.Row="1"
                     Grid.Column="1"
                     Margin="0,0,0,5"
                     Visibility="Collapsed"/>

                                    <TextBlock x:Name="AccountNumberLabel"
                       Grid.Row="2"
                       Grid.Column="0"
                       Text="Account Number:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,5"
                       Visibility="Collapsed"/>

                                    <TextBox x:Name="AccountNumberBox"
                     Grid.Row="2"
                     Grid.Column="1"
                     Margin="0,0,0,5"
                     Visibility="Collapsed"/>

                                    <TextBlock x:Name="PaymentOptionLabel"
                       Grid.Row="3"
                       Grid.Column="0"
                       Text="Payment Option:"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Visibility="Collapsed"/>

                                    <ComboBox x:Name="PaymentOptionBox"
                      Grid.Row="3"
                      Grid.Column="1"
                      Visibility="Collapsed">
                      
                                        
                                        <ComboBoxItem Content="Full Payment"/>
                                        <ComboBoxItem Content="Monthly Instalments"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Staff Info -->
                        <Border BorderBrush="Gray"
                        BorderThickness="1"
                        Padding="10"
                        Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Staff Information"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                       Text="Processed By:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>

                                    <TextBlock x:Name="ProcessedByBox"
                                     Grid.Column="1"
                                            
                                             Background="#EEE"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Payment Summary -->
                        <Border BorderBrush="Gray"
                        BorderThickness="1"
                        Padding="10">
                            <StackPanel>
                                <TextBlock Text="Payment Summary"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                                <TextBlock x:Name="BasePriceText"
                                   Text="Base Price: £0.00"
                                   Margin="0,0,0,5"/>

                                <TextBlock x:Name="DiscountAmountText"
                                   Text="Discount Amount: £0.00"
                                   Margin="0,0,0,5"/>

                                <TextBlock x:Name="TotalPayableText"
                                   Text="Total Payable: £0.00"
                                   FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Bottom Buttons -->
            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Back button on the left -->
                <Button Grid.Column="0"
            Content="Back"
            Width="100"
            Height="35"
            HorizontalAlignment="Left"
            Click="BackFromProcessOrders_Click"/>

                <!-- Delete + Process on the right -->
                <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
                    <Button Content="Delete Order"
                Width="130"
                Height="35"
                Margin="0,0,10,0"
                Click="DeleteOrder_Click"/>

                    <Button Content="Process Order"
                Width="130"
                Height="35"
                Click="ProcessSelectedOrder_Click"/>
                </StackPanel>
            </Grid>
        </Grid>

        
        
        <!-- 4. UPDATE INVENTORY PANEL -->
        <Grid x:Name="InventoryPanel" Visibility="Collapsed" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Update Inventory"
               FontSize="24"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.3*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Phone List -->
                <Grid Grid.Column="0" Margin="0,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search bar -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">

                        <TextBlock Text="Search manufacturer or model"
                                   
                                     Margin="0,0,0,5"/>

                        <StackPanel Orientation="Horizontal">

                            <TextBox x:Name="InventorySearchBox"
                                     Width="244"
                                     Height="30"
                                     Margin="0,0,10,0"
                                     KeyDown="InventorySearchBox_KeyDown"/> 

                            <Button Content="Search"
                                    Width="125"
                                    Height="30"
                                    Margin="0,0,10,0"
                                    Click="SearchInventory_Click"/> 

                            <Button Content="Show All"
                                    Width="125"
                                    Height="30"
                                    Margin="0,0,10,0"
                                    Click="ShowAllInventory_Click"/>

                        </StackPanel>

                    </StackPanel>

                    <!-- Inventory list -->
                    <DataGrid x:Name="InventoryPhonesGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="InventoryPhonesGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Phone ID" Binding="{Binding PhoneID}" Width="58"/>
                            <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="1.4*"/>
                            <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="2*"/>
                            <DataGridTextColumn Header="Storage" Binding="{Binding Storage, StringFormat={}{0} GB}" Width="55"/>
                            <DataGridTextColumn Header="Release Year" Binding="{Binding ReleaseYear}" Width="70"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=£{0:F2}}" Width="70"/>
                            <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- RIGHT: Action Panel -->
                <Border Grid.Column="1"
                BorderBrush="Gray"
                BorderThickness="1"
                Padding="10">
                    <StackPanel>
                        <TextBlock Text="Inventory Action"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                        <TextBlock Text="Choose Action"/>
                        <ComboBox x:Name="InventoryActionBox"
                          SelectionChanged="InventoryActionBox_SelectionChanged"
                          Margin="0,0,0,12">
                            <ComboBoxItem Content="Add Phone"/>
                            <ComboBoxItem Content="Remove Phone"/>
                            <ComboBoxItem Content="Update Stock"/>
                            <ComboBoxItem Content="Change Price"/>
                        </ComboBox>

                        <TextBlock Text="Manufacturer" x:Name="InvManufacturerLabel"/>
                        <TextBox x:Name="InvManufacturerBox" Margin="0,0,0,8"/>

                        <TextBlock Text="Model" x:Name="InvModelLabel"/>
                        <TextBox x:Name="InvModelBox" Margin="0,0,0,8"/>

                        <TextBlock Text="Storage (GB)" x:Name="InvStorageLabel"/>

                        <ComboBox x:Name="InvStorageBox"
                                  Margin="0,0,0,12"
                                  SelectedIndex="2">                

                            <ComboBoxItem Content="32"/>
                            <ComboBoxItem Content="64"/>
                            <ComboBoxItem Content="128"/>
                            <ComboBoxItem Content="256"/>
                            <ComboBoxItem Content="512"/>
                            <ComboBoxItem Content="1024"/>
                            <ComboBoxItem Content="2048"/>
                            <ComboBoxItem Content="4096"/>

                        </ComboBox>

                        <TextBlock Text="Release Year" x:Name="InvReleaseYearLabel"/>
                        <TextBox x:Name="InvReleaseYearBox" 
                                 Margin="0,0,0,8" 
                                 MaxLength="4"
                                 PreviewTextInput="NumbersOnly"/>

                        <!-- Main price field -->
                        <TextBlock Text="Curent Price" x:Name="InvPriceLabel" Visibility="Collapsed"/>
                        <TextBox x:Name="InvPriceBox"
                         Margin="0,0,0,8"
                         Visibility="Collapsed"
                         MaxLength="8"
                         PreviewTextInput="PriceInput"/>

                        <!-- Change price fields -->
                        <TextBlock Text="Current Price" x:Name="InvCurrentPriceLabel" Visibility="Collapsed"/>
                        <TextBox x:Name="InvCurrentPriceBox"
                         Margin="0,0,0,8"
                         IsReadOnly="True"
                         Visibility="Collapsed"/>

                        <TextBlock Text="New Price" x:Name="InvNewPriceLabel" Visibility="Collapsed"/>
                        <TextBox x:Name="InvNewPriceBox"
                         Margin="0,0,0,8"
                         Visibility="Collapsed"
                         MaxLength="7"
                         PreviewTextInput="PriceInput"/>

                        <!-- Add phone stock -->
                        <TextBlock Text="Initial Stock" x:Name="InvInitialStockLabel" Visibility="Collapsed"/>
                        <TextBox x:Name="InvInitialStockBox"
                         Margin="0,0,0,8"
                         Visibility="Collapsed"
                         MaxLength="3"
                         PreviewTextInput="NumbersOnly"/>

                        <!-- Update stock fields -->
                        <TextBlock Text="Old Stock" x:Name="InvOldStockLabel" Visibility="Collapsed"/>
                        <TextBox x:Name="InvOldStockBox"
                         Margin="0,0,0,8"
                         IsReadOnly="True"
                         Visibility="Collapsed"/>

                        <TextBlock Text="New Stock" x:Name="InvNewStockLabel" Visibility="Collapsed"/>
                        <TextBox x:Name="InvNewStockBox"
                         Margin="0,0,0,8"
                         Visibility="Collapsed"
                         MaxLength="3"
                         PreviewTextInput="NumbersOnly"/>

                        <Button x:Name="InventoryActionButton"
                        Content="Apply"
                        Height="35"
                        Click="InventoryActionButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        

        <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Left"
                Margin="0,10,0,0">
                <Button Content="Back"
                Width="100"
                Height ="30"
                Margin="5"
                Click="BackFromInventory_Click"/>
            </StackPanel>
        </Grid>
        
     
        <!-- 5. VIEW TRANSACTIONS PANEL -->
        <Grid x:Name="TransactionsPanel" Visibility="Collapsed" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="View Transactions"
               FontSize="24"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT MENU -->
                <Border Grid.Column="0"
                BorderBrush="Gray"
                BorderThickness="1"
                Padding="10">
                    <StackPanel>
                        <Button Content="1. View Shop Balance"
                                Height="40"
                                Margin="0,0,0,10"
                                Click="ViewShopBalance_Click"/>

                        <Button Content="2. View Order History"
                                Height="40"
                                Margin="0,0,0,10"
                                Click="ViewOrderHistory_Click"/>

                        <Button Content="3. View Clients"
                                Height="40"
                                Margin="0,0,0,10"
                                Click="ViewClients_Click"/>

                        <Button Content="4. View Inventory Log"
                                Height="40"
                                Margin="0,0,0,10"
                                Click="ViewInventoryLog_Click"/>

                        <Button Content="5. Back"
                                Height="40"
                                Click="BackFromTransactions_Click"/>    
                    </StackPanel>
                </Border>

                <!-- RIGHT CONTENT -->
                <Grid Grid.Column="2">
                    <Border x:Name="TransactionsWelcomePanel"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="20"
                    Visibility="Visible">
                        <TextBlock Text="Choose an option from the left menu."
                           FontSize="16"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                    </Border>

                    <Border x:Name="ShopBalancePanel"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="20"
                    Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Shop Balance Summary"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,15"/>


                            <TextBlock Text="Current Phones in Stock:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="StockUnitsText" Text="0" Margin="0,0,0,10"/>

                            <TextBlock Text="Current Stock Value:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="StockValueText" Text="£0.00" Margin="0,0,0,10"/>

                            <TextBlock Text="Total Phones Sold:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="PhonesSoldText" Text="0" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Total Revenue Earned:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="RevenueText" Text="£0.00" Margin="0,0,0,10"/>

                            <TextBlock Text="Total Discount Applied:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="DiscountAppliedText" Text="£0.00" Margin="0,0,0,10"/>

                            <Separator Margin="0,10,0,10"/>

                            <TextBlock Text="TOTAL SHOP BALANCE:" FontWeight="Bold"/>
                            <TextBlock x:Name="TotalBalanceText"
                               Text="£0.00"
                               FontSize="22"
                               FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="OrderHistoryPanel"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10"
                    Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Order History"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                            <DataGrid x:Name="OrderHistoryGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="True"
                              IsReadOnly="True">
                                
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border x:Name="ClientsPanel"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10"
                    Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Clients"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                            <DataGrid x:Name="ClientsGrid"
                              Grid.Row="1"
                              AutoGenerateColumns="True"
                              IsReadOnly="True">
                                
                            </DataGrid>
                        </Grid>
                    </Border>

                    <Border x:Name="InventoryLogPanel"
        BorderBrush="Gray"
        BorderThickness="1"
        Padding="10"
        Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Inventory Log"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

                            <DataGrid x:Name="InventoryLogGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="True"
                  IsReadOnly="True">
                                
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>