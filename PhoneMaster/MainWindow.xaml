<Window x:Class="PhoneMaster.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhoneMaster"
        Height="640"
        Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <!-- WELCOME SCREEN -->
        <Grid x:Name="WelcomePanel" Background="#1f1f1f" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <TextBlock Text="WELCOME TO"
                           Foreground="White"
                           FontSize="22"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="PhoneMaster"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="Bold"
                           Margin="0,10,0,30"
                           HorizontalAlignment="Center"/>

                <Button Content="Press to Start"
                        Width="180"
                        Height="45"
                        FontSize="16"
                        Click="StartButton_Click"/>
            </StackPanel>
        </Grid>

        <!-- MAIN MENU -->
        <Grid x:Name="MenuPanel" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="300">

                <TextBlock Text="PHONE MASTER"
                           FontSize="26"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <Button Content="Phones and Plans"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="Phones_Click"/>

                <Button Content="Create Order"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="CreateOrder_Click"/>

                <Button Content="Process Order"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="ProcessOrder_Click"/>

                <Button Content="Update Inventory"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="Inventory_Click"/>

                <Button Content="View Transactions"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="Transactions_Click"/>
            </StackPanel>
        </Grid>

        <!-- PHONES PANEL -->
        <Grid x:Name="PhonesPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto" MinHeight="75.157"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Phones and Plans"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="10,10,10,10"/>

            <StackPanel Grid.Row="1" Margin="10,10,10,10">
                <TextBlock Text="Search manufacturer or model"
                           Margin="0,0,0,5"/>

                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="SearchBox"
                             Width="250"
                             Height="28"
                             Margin="0,0,10,0"/>

                    <Button Content="Search"
                            Width="100"
                            Click="SearchPhone_Click"/>

                    <Button Content="Back"
                            Width="100"
                            Margin="10,0,0,0"
                            Click="BackToMenu_Click"/>
                </StackPanel>
            </StackPanel>

            <DataGrid x:Name="PhonesGrid"
                      Grid.Row="2"
                      Margin="10,10,10,63"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"/>

            <TextBlock Grid.Row="3"
                       Margin="10,10,10,10"
                       Text="Plans: Standard (£10/month) | Premium (£20/month)"
                       FontWeight="SemiBold"/>
        </Grid>

        <!-- CREATE ORDER PANEL -->
        <Grid x:Name="CreateOrderPanel" Visibility="V" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Create Order"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <DataGrid x:Name="CreateOrderPhonesGrid"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          Margin="0,0,10,0"
                          SelectionChanged="OrderInputChanged"/>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Quantity"/>
                    <TextBox x:Name="QuantityTextBox"
                             Margin="0,0,0,10"
                             TextChanged="OrderInputChanged"/>

                    <TextBlock Text="Client Type"/>
                    <ComboBox x:Name="ClientTypeBox"
                            Margin="0,0,0,10"
                            SelectionChanged="ClientTypeBox_SelectionChanged">
                        <ComboBoxItem Content="Customer"/>
                        <ComboBoxItem Content="Company"/>
                    </ComboBox>

                    <TextBlock Text="Contract Type"/>
                    <ComboBox x:Name="ContractTypeBox"
                              Margin="0,0,0,10"
                              SelectionChanged="ContractTypeBox_SelectionChanged">
                        <ComboBoxItem Content="SIM-Free"/>
                        <ComboBoxItem Content="Phone + SIM Package"/>
                        <ComboBoxItem Content="Hire Contract"/>
                    </ComboBox>

                    <TextBlock Text="Plan Type"/>
                    <ComboBox x:Name="PlanTypeBox" 
                              Margin="0,0,0,10"
                              SelectionChanged="OrderInputChanged">
                        <ComboBoxItem Content="Standard"/>
                        <ComboBoxItem Content="Premium"/>

                    </ComboBox>

                    <TextBlock x:Name="DurationLabel" Text="Duration" Visibility="Collapsed"/>
                    <ComboBox x:Name="DurationBox" 
                              Margin="0,0,0,20" 
                              Visibility="Collapsed" 
                              SelectionChanged="OrderInputChanged"/>

                    <TextBlock Text="Client Name"/>
                    <TextBox x:Name="ClientNameBox" Margin="0,0,0,8"/>

                    <TextBlock Text="Email"/>
                    <TextBox x:Name="EmailBox" Margin="0,0,0,8"/>

                    <TextBlock Text="Contact Phone"/>
                    <TextBox x:Name="PhoneBox" Margin="0,0,0,8"/>

                    <TextBlock Text="Address"/>
                    <TextBox x:Name="AddressBox" Margin="0,0,0,8"/>

                    <TextBlock Text="Postcode"/>
                    <TextBox x:Name="PostcodeBox" Margin="0,0,0,8"/>

                    <TextBlock Text="Town"/>
                    <TextBox x:Name="TownBox" Margin="0,0,0,8"/>

                    <TextBlock x:Name="VatLabel" Text="VAT Number" Visibility="Collapsed"/>
                    <TextBox x:Name="VatNumberBox" Margin="0,0,0,8" Visibility="Collapsed"/>

                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Back"
                        Width="100"
                        Margin="10"
                        Click="BackFromCreateOrder_Click"/>



                <TextBlock Text="Order Summary"
                             FontWeight="Bold"
                             Margin="0,15,0,8"/>

                <Border BorderBrush="Gray"
                        BorderThickness="1"
                        Padding="10"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Total Price:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TotalPriceText"
                          Text="£0.00"
                             Margin="0,0,0,8"/>

                        <TextBlock Text="Monthly Cost:" FontWeight="SemiBold"/>
                        <TextBlock x:Name="MonthlyCostText"
                             Text="£0.00"/>
                    </StackPanel>
                </Border>

                <Button Content="Send to Staff"
                        Width="120"
                        Margin="10"
                        Click="SendOrder_Click"/>
            </StackPanel>
        </Grid>

        <!-- PROCESS ORDER PANEL -->
        <Grid x:Name="ProcessOrdersPanel" Visibility="Collapsed" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Process Orders"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <DataGrid x:Name="PendingOrdersGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="*"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding PhoneName}" Width="*"/>
                    <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                    <DataGridTextColumn Header="Contract" Binding="{Binding ContractType}" Width="150"/>
                    <DataGridTextColumn Header="Total Price" Binding="{Binding TotalPrice, StringFormat=£{0:F2}}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">

                <Button Content="Process Order"
                        Width="130"
                        Margin="5"
                        Click="ProcessSelectedOrder_Click"/>

                <Button Content="Delete Order"
                        Width="130"
                        Margin="5"
                        Click="DeleteOrder_Click"/>

                <Button Content="Back"
                        Width="100"
                        Margin="5"
                        Click="BackFromProcessOrders_Click"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>