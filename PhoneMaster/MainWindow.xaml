<Window x:Class="PhoneMaster.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PhoneMaster"
        Height="600"
        Width="900"
        Icon="\Assets\favicon.ico"
        WindowStartupLocation="CenterScreen">

    <Grid>

        <!-- WELCOME SCREEN -->
        <Grid x:Name="WelcomePanel" Visibility="Visible">

            <Grid.Background>
                <ImageBrush ImageSource="/Assets/logo.png"
                    Stretch="Uniform"/>
            </Grid.Background>

            <Border Background="#88000000">


                <Button Content="ENTER"
                        VerticalAlignment="Top"
                   Width="120"
                   Height="50"
                     
                    Click="StartButton_Click" 
                        Margin="390,467,390,0" 
                       
                        FontWeight="Bold" Background="#FFB0E7B3" Opacity="0.9" BorderBrush="#FFEE0C0C"/>

            </Border>



        </Grid>

        <!-- MAIN MENU -->
        <Grid x:Name="MenuPanel" Visibility="Collapsed">

            <StackPanel HorizontalAlignment="Center"
                        Background= "#66000000"
                        VerticalAlignment="Center"
                        Width="300">

                <TextBlock Text="PHONE MASTER"
                           FontSize="26"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <Button Content="Phones and Plans"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="Phones_Click"/>

                <Button Content="Create Order"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="CreateOrder_Click"/>

                <Button Content="Process Order"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="ProcessOrder_Click"/>

                <Button Content="Update Inventory"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="Inventory_Click"/>

                <Button Content="View Transactions"
                        Height="45"
                        Margin="0,5,0,5"
                        Click="Transactions_Click"/>
            </StackPanel>
        </Grid>

        <!-- PHONES PANEL -->
        <Grid x:Name="PhonesPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto" MinHeight="75.157"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Phones and Plans"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="10,10,10,10"/>

            <StackPanel Grid.Row="1" Margin="10,10,10,10">
                <TextBlock Text="Search manufacturer or model"
                           Margin="0,0,0,5"/>

                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="SearchBox"
                             Width="220"
                             Height="30"
                             Margin="0,0,10,0"
                             KeyDown="SearchBox_KeyDown"/>

                    <Button Content="Search"
                            Width="100"
                            Click="SearchPhone_Click"
                            />

                    <Button Content="Back"
                            Width="100"
                            Margin="10,0,0,0"
                            Click="BackToMenu_Click"/>
                </StackPanel>
            </StackPanel>

            <DataGrid x:Name="PhonesGrid"
                      Grid.Row="2"
                      Margin="10,10,10,63"
                      AutoGenerateColumns="True"
                      IsReadOnly="True"/>

            <TextBlock Grid.Row="3"
                       Margin="10,10,10,10"
                       Text="Plans: Standard (£10/month) | Premium (£20/month)"
                       FontWeight="SemiBold"/>
        </Grid>

        <!-- CREATE ORDER PANEL -->
        <Grid x:Name="CreateOrderPanel" Visibility="Collapsed" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Create Order"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <DataGrid x:Name="CreateOrderPhonesGrid"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          SelectionChanged="OrderInputChanged" Margin="0,0,10,0"/>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Quantity"/>
                    <TextBox x:Name="QuantityTextBox"
                             Margin="0,0,0,10"
                             TextChanged="OrderInputChanged"/>

                    <TextBlock Text="Client Type"/>
                    <ComboBox x:Name="ClientTypeBox"
                            Margin="0,0,0,10"
                            SelectionChanged="ClientTypeBox_SelectionChanged">
                        <ComboBoxItem Content="Customer"/>
                        <ComboBoxItem Content="Company"/>
                    </ComboBox>

                    <TextBlock Text="Contract Type"/>
                    <ComboBox x:Name="ContractTypeBox"
                              Margin="0,0,0,10"
                              SelectionChanged="ContractTypeBox_SelectionChanged">
                        <ComboBoxItem Content="SIM-Free"/>
                        <ComboBoxItem Content="Phone + SIM Package"/>
                        <ComboBoxItem Content="Hire Contract"/>
                    </ComboBox>

                    <TextBlock Text="Plan Type"/>
                    <ComboBox x:Name="PlanTypeBox" 
                              Margin="0,0,0,10"
                              SelectionChanged="OrderInputChanged">
                        <ComboBoxItem Content="Standard"/>
                        <ComboBoxItem Content="Premium"/>

                    </ComboBox>

                    <TextBlock x:Name="DurationLabel" Text="Duration" Visibility="Visible"/>
                    <ComboBox x:Name="DurationBox" 
                              Margin="0,0,0,20" 
                              Visibility="Collapsed" 
                              SelectionChanged="OrderInputChanged"/>
                    <TextBlock Text="Order Summary"
                             FontWeight="Bold"
                             />
                    <Border BorderBrush="Gray"
                        BorderThickness="1"
                        Padding="10" Height="148"
                        >
                        <StackPanel>
                            <TextBlock Text="Total Price:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TotalPriceText"
                          Text="£0.00"
                             Margin="0,0,0,8"/>

                            <TextBlock Text="Monthly Cost:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="MonthlyCostText"
                             Text="£0.00"/>
                        </StackPanel>
                    </Border>


                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Back"
                        Width="100"
                        Margin="10"
                        Click="BackFromCreateOrder_Click"/>

                <Button Content="Continue"
                        Width="120"
                        Margin="10"
                        Click="ContinueOrder_Click"/>
            </StackPanel>
        </Grid>

        <!-- PROCESS ORDER PANEL -->
        <Grid x:Name="ProcessOrdersPanel" Visibility="Collapsed" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Process Orders"
               FontSize="24"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE: Pending Orders -->
                <Grid Grid.Column="0" Margin="0,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Pending orders list -->
                    <DataGrid x:Name="PendingOrdersGrid"
                      Grid.Row="0"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionChanged="PendingOrdersGrid_SelectionChanged"
                      Margin="0,0,0,10">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="*"/>
                            <DataGridTextColumn Header="Phone" Binding="{Binding PhoneName}" Width="*"/>
                            <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="100"/>
                            <DataGridTextColumn Header="Contract" Binding="{Binding ContractType}" Width="150"/>
                            <DataGridTextColumn Header="Total Price" Binding="{Binding TotalPrice, StringFormat=£{0:F2}}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Selected order summary -->
                    <Border Grid.Row="1"
                    BorderBrush="Gray"
                    BorderThickness="1"
                    Padding="10"
                    Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Selected Order Summary"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                            <TextBlock x:Name="ProcessSummaryText"
                               Text="Select an order to view details."
                               TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- RIGHT SIDE: Processing Panel -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Discount Section -->
                        <Border BorderBrush="Gray"
                        BorderThickness="1"
                        Padding="10"
                        Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Discount Approval"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="Apply Discount:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,5"/>

                                    <ComboBox x:Name="ApplyDiscountBox"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      SelectionChanged="ApplyDiscountBox_SelectionChanged"
                                      Margin="0,0,0,5">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>

                                    <TextBlock x:Name="ManagerUsernameLabel"
                                       Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Manager Username:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,5"
                                       Visibility="Collapsed"/>

                                    <TextBox x:Name="ManagerUsernameBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,0,0,5"
                                     Visibility="Collapsed"/>

                                    <TextBlock x:Name="ManagerPasswordLabel"
                                       Grid.Row="2"
                                       Grid.Column="0"
                                       Text="Manager Password:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,5"
                                       Visibility="Collapsed"/>

                                    <PasswordBox x:Name="ManagerPasswordBox"
                                         Grid.Row="2"
                                         Grid.Column="1"
                                         Margin="0,0,0,5"
                                         Visibility="Collapsed"/>

                                    <TextBlock x:Name="DiscountPercentLabel"
                                       Grid.Row="3"
                                       Grid.Column="0"
                                       Text="Discount %:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Visibility="Collapsed"/>

                                    <TextBox x:Name="DiscountPercentBox"
                                     Grid.Row="3"
                                     Grid.Column="1"
                                     TextChanged="DiscountPercentBox_TextChanged"
                                     Visibility="Collapsed"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Payment Section -->
                        <Border BorderBrush="Gray"
                        BorderThickness="1"
                        Padding="10"
                        Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Payment Details"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="Payment Method:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,5"/>

                                    <ComboBox x:Name="PaymentMethodBox"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                     
                                      SelectionChanged="PaymentMethodBox_SelectionChanged"
                                      Margin="0,0,0,5">
                                        <ComboBoxItem Content="CASH"/>
                                        <ComboBoxItem Content="CARD"/>
                                    </ComboBox>

                                    <TextBlock x:Name="SortCodeLabel"
                                       Grid.Row="1"
                                       Grid.Column="0"
                                       Text="Sort Code:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,5"
                                       Visibility="Collapsed"/>

                                    <TextBox x:Name="SortCodeBox"
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     Margin="0,0,0,5"
                                     Visibility="Collapsed"/>

                                    <TextBlock x:Name="AccountNumberLabel"
                                       Grid.Row="2"
                                       Grid.Column="0"
                                       Text="Account Number:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Visibility="Collapsed"/>

                                    <TextBox x:Name="AccountNumberBox"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     Visibility="Collapsed"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Staff Info -->
                        <Border BorderBrush="Gray"
                        BorderThickness="1"
                        Padding="10"
                        Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Staff Information"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                       Text="Processed By:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>

                                    <TextBox x:Name="ProcessedByBox"
                                     Grid.Column="1"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Payment Summary -->
                        <Border BorderBrush="Gray"
                        BorderThickness="1"
                        Padding="10">
                            <StackPanel>
                                <TextBlock Text="Payment Summary"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                                <TextBlock x:Name="BasePriceText"
                                   Text="Base Price: £0.00"
                                   Margin="0,0,0,5"/>

                                <TextBlock x:Name="DiscountAmountText"
                                   Text="Discount Amount: £0.00"
                                   Margin="0,0,0,5"/>

                                <TextBlock x:Name="TotalPayableText"
                                   Text="Total Payable: £0.00"
                                   FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Buttons -->
            <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,10,0,0">
                <Button Content="Process Order"
                Width="130"
                Margin="5"
                Click="ProcessSelectedOrder_Click"/>

                <Button Content="Delete Order"
                Width="130"
                Margin="5"
                Click="DeleteOrder_Click"/>

                <Button Content="Back"
                Width="100"
                Margin="5"
                Click="BackFromProcessOrders_Click"/>
            </StackPanel>
        </Grid>
        
        <!-- UPDATE INVENTORY PANEL -->
        <Grid x:Name="InventoryPanel" Visibility="Collapsed" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Update Inventory"
               FontSize="24"
               FontWeight="Bold"
               Margin="0,0,0,10"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.3*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Phone List -->
                <Grid Grid.Column="0" Margin="0,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search bar -->
                    <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Margin="0,0,0,10">
                        <TextBox x:Name="InventorySearchBox"
                 Width="220"
                 Height="30"
                 Margin="0,0,10,0"
                 KeyDown="InventorySearchBox_KeyDown" />

                        <Button Content="Search"
                Width="100"
                Height="30"
                Margin="0,0,10,0"
                Click="SearchInventory_Click"/>

                        <Button Content="Show All"
                Width="100"
                Height="30"
                Click="ShowAllInventory_Click"/>
                    </StackPanel>

                    <!-- Inventory list -->
                    <DataGrid x:Name="InventoryPhonesGrid"
              Grid.Row="1"
              AutoGenerateColumns="False"
              IsReadOnly="True"
              SelectionMode="Single"
              SelectionChanged="InventoryPhonesGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Phone ID" Binding="{Binding PhoneID}" Width="50"/>
                            <DataGridTextColumn Header="Manufacturer" Binding="{Binding Manufacturer}" Width="90"/>
                            <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="120"/>
                            <DataGridTextColumn Header="Storage" Binding="{Binding Storage, StringFormat={}{0}GB}" Width="50"/>
                            <DataGridTextColumn Header="Release Year" Binding="{Binding ReleaseYear}" Width="50"/>
                            <DataGridTextColumn Header="Price" Binding="{Binding Price, StringFormat=£{0:F2}}" Width="70"/>
                            <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="50"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- RIGHT: Action Panel -->
                <Border Grid.Column="1"
                BorderBrush="Gray"
                BorderThickness="1"
                Padding="10">
                    <StackPanel>
                        <TextBlock Text="Inventory Action"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                        <TextBlock Text="Choose Action"/>
                        <ComboBox x:Name="InventoryActionBox"
                          SelectionChanged="InventoryActionBox_SelectionChanged"
                          Margin="0,0,0,12">
                            <ComboBoxItem Content="Add Phone"/>
                            <ComboBoxItem Content="Remove Phone"/>
                            <ComboBoxItem Content="Update Stock"/>
                            <ComboBoxItem Content="Change Price"/>
                        </ComboBox>

                        <TextBlock Text="Manufacturer" x:Name="InvManufacturerLabel"/>
                        <TextBox x:Name="InvManufacturerBox" Margin="0,0,0,8"/>

                        <TextBlock Text="Model" x:Name="InvModelLabel"/>
                        <TextBox x:Name="InvModelBox" Margin="0,0,0,8"/>

                        <TextBlock Text="Storage" x:Name="InvStorageLabel"/>
                        <TextBox x:Name="InvStorageBox" Margin="0,0,0,12"/>

                        <TextBlock Text="Release Year" x:Name="InvReleaseYearLabel"/>
                        <TextBox x:Name="InvReleaseYearBox" Margin="0,0,0,8"/>
                        
                        <TextBlock Text="Price" x:Name="InvPriceLabel"/>
                        <TextBox x:Name="InvPriceBox" Margin="0,0,0,8"/>

                        <TextBlock Text="Stock" x:Name="InvStockLabel"/>
                        <TextBox x:Name="InvStockBox" Margin="0,0,0,8"/>


                        <Button x:Name="InventoryActionButton"
                        Content="Apply"
                        Height="35"
                        Click="InventoryActionButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,10,0,0">
                <Button Content="Back"
                Width="100"
                Margin="5"
                Click="BackFromInventory_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>