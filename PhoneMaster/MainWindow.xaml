<Window x:Class="PhoneMaster.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PhoneMaster"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="assets/favicon.ico"
        Background="White">

    <Window.Resources>
        <!-- Style for welcome screen -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#FFB0E7B3"/>
            <Setter Property="BorderBrush" Value="#FF2196F3"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="#FF1E3A8A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                CornerRadius="30"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12"
                                                  ShadowDepth="2"
                                                  Opacity="0.18"/>
                            </Border.Effect>

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFCCE4FF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#FF1565C0"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FFA8D5AC"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>

        <!-- WELCOME SCREEN -->
        <Grid x:Name="WelcomePanel" Visibility="Visible" Grid.ColumnSpan="2">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFF8FBFF" Offset="0"/>
                    <GradientStop Color="#FFEAF4FF" Offset="0.55"/>
                    <GradientStop Color="#FFDDEEFF" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Margin="0,-20,0,0">

                    <Border Background="#FFDDEEFF"
                            CornerRadius="20"
                            Padding="20"
                            Margin="0,0,0,22">
                        <Image Source="/Assets/welcomelogo.png"
                               Width="560"
                               Stretch="Uniform"/>
                    </Border>

                    <TextBlock Text="Stock, contracts, orders and sales in one place"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#FF44546A"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,28"/>

                    <Button Content="START"
                            Width="190"
                            Height="62"
                            HorizontalAlignment="Center"
                            FontSize="22"
                            Style="{StaticResource RoundedButton}"
                            Click="StartButton_Click"
                            Background="#FFB8E0BA"
                            BorderBrush="#FF2196F3"
                            BorderThickness="2"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Grid>


        <!-- MAIN MENU -->
        <Grid x:Name="MenuPanel" Visibility="Collapsed" Grid.ColumnSpan="2">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FFF8FBFF" Offset="0"/>
                    <GradientStop Color="#FFEAF4FF" Offset="0.55"/>
                    <GradientStop Color="#FFDDEEFF" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Border Width="360"
            Padding="28"
            CornerRadius="24"
            Background="#F9FFFFFF"
            BorderBrush="#22000000"
            BorderThickness="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                              ShadowDepth="3"
                              Opacity="0.18"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="PHONE MASTER"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#FF1E3A8A"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6"/>

                    <TextBlock Text="Main Menu"
                       FontSize="15"
                       Foreground="#FF5F6B7A"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,22"/>

                    <Button Content="Phones and Plans"
                    Height="46"
                    Margin="0,6,0,6"
                    Style="{StaticResource MenuButton}"
                    Click="Phones_Click"/>

                    <Button Content="Create Order"
                    Height="46"
                    Margin="0,6,0,6"
                    Style="{StaticResource MenuButton}"
                    Click="CreateOrder_Click"/>

                    <Button Content="Process Order"
                    Height="46"
                    Margin="0,6,0,6"
                    Style="{StaticResource MenuButton}"
                    Click="ProcessOrder_Click"/>

                    <Button Content="Inventory Management"
                    Height="46"
                    Margin="0,6,0,6"
                    Style="{StaticResource MenuButton}"
                    Click="Inventory_Click"/>

                    <Button Content="View Transactions"
                    Height="46"
                    Margin="0,6,0,6"
                    Style="{StaticResource MenuButton}"
                    Click="Transactions_Click"/>

                    <Button Content="Back"
                    Height="46"
                    Margin="0,14,0,0"
                    Style="{StaticResource ExitMenuButton}"
                    Click="ExitButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 1. VIEW PHONES PANEL -->
        <Grid x:Name="PhonesPanel" Visibility="Collapsed" Margin="16,16,16,16" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Phones and Plans"
               FontSize="28"
               FontWeight="Bold"
               Foreground="#FF1E3A8A"
               Margin="0,0,0,14"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE -->
                <Border Grid.Column="0"
                Margin="0,0,16,0"
                Padding="14"
                CornerRadius="20"
                Background="#F9FFFFFF"
                BorderBrush="#22000000"
                BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14"
                                  ShadowDepth="2"
                                  Opacity="0.14"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Search area -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Search manufacturer or model"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF44546A"
                               Margin="0,0,0,6"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="SearchBox"
                                 Grid.Column="0"
                                 Height="34"
                                 Margin="0,0,10,0"
                                 Padding="8,4"
                                 VerticalContentAlignment="Center"
                                 KeyDown="SearchBox_KeyDown"/>

                                <Button Content="Search"
                                Grid.Column="1"
                                Height="34"
                                Margin="0,0,10,0"
                                Style="{StaticResource MenuButton}"
                                Click="SearchPhone_Click"/>

                                <Button Content="Show All"
                                Grid.Column="2"
                                Height="34"
                                Style="{StaticResource MenuButton}"
                                Click="ShowAllPhones_Click"/>
                            </Grid>
                        </StackPanel>

                        <!-- Phones grid -->
                        <DataGrid x:Name="PhonesGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="PhonesGrid_SelectionChanged"
                          Margin="0,0,0,12"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">

                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#FFEAF4FF"/>
                                    <Setter Property="Foreground" Value="#FF1E3A8A"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderBrush" Value="#FFD0D7DE"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFEEF8FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#FFE9F4FF"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Phone ID"
                                            Binding="{Binding PhoneID}"
                                            Width="70"/>

                                <DataGridTextColumn Header="Manufacturer"
                                            Binding="{Binding Manufacturer}"
                                            Width="1.2*"/>

                                <DataGridTextColumn Header="Model"
                                            Binding="{Binding Model}"
                                            Width="1.7*"/>

                                <DataGridTextColumn Header="Storage"
                                            Binding="{Binding Storage, StringFormat={}{0} GB}"
                                            Width="80"/>

                                <DataGridTextColumn Header="Year"
                                            Binding="{Binding ReleaseYear}"
                                            Width="80"/>

                                <DataGridTextColumn Header="Price"
                                            Binding="{Binding Price, StringFormat=£{0:F2}}"
                                            Width="90"/>

                                <DataGridTextColumn Header="Stock"
                                            Binding="{Binding Stock}"
                                            Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Back button -->
                        <Button Grid.Row="2"
                        Content="Back"
                        Width="110"
                        Height="36"
                        HorizontalAlignment="Left"
                        Style="{StaticResource ExitMenuButton}"
                        Click="BackToMenu_Click"/>
                    </Grid>
                </Border>

                <!-- RIGHT SIDE -->
                <Border Grid.Column="1"
                Padding="14"
                CornerRadius="20"
                Background="#F9FFFFFF"
                BorderBrush="#22000000"
                BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14"
                                  ShadowDepth="2"
                                  Opacity="0.14"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="220"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Selected Phone"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#FF1E3A8A"
                           Margin="0,0,0,12"/>

                        <Border Grid.Row="1"
                        Background="#FFFFFFFF"
                        BorderBrush="#FFD9E2EC"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="8"
                        Margin="0,0,0,12">
                            <Image x:Name="SelectedPhoneImage"
                           Stretch="Uniform"/>
                        </Border>

                        <TextBlock Grid.Row="2"
                           x:Name="SelectedPhoneText"
                           Text="No phone selected"
                           TextWrapping="Wrap"
                           FontSize="14"
                           Foreground="#FF334155"
                           Margin="0,0,0,14"/>

                        <TextBlock Grid.Row="3"
                           Text="Available Plans"
                           FontWeight="Bold"
                           FontSize="15"
                           Foreground="#FF1F2937"
                           Margin="0,0,0,8"/>

                        <Border Grid.Row="4"
                        Background="#FFF8FBFF"
                        BorderBrush="#FFD9E2EC"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12">
                            <StackPanel>
                                <TextBlock Text="Standard Plan"
                                   FontWeight="SemiBold"
                                   Foreground="#FF1E3A8A"/>
                                <TextBlock Text="£10 per month"
                                   Margin="0,2,0,10"
                                   Foreground="#FF475569"/>

                                <TextBlock Text="Premium Plan"
                                   FontWeight="SemiBold"
                                   Foreground="#FF1E3A8A"/>
                                <TextBlock Text="£20 per month"
                                   Margin="0,2,0,0"
                                   Foreground="#FF475569"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>


        <!-- 2. CREATE ORDER PANEL -->
        <Grid x:Name="CreateOrderPanel" Visibility="Collapsed" Margin="16,16,16,16" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Create Order"
               FontSize="28"
               FontWeight="Bold"
               Foreground="#FF1E3A8A"
               Margin="0,0,0,14"/>

            <!-- Main content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE -->
                <Border Grid.Column="0"
                Margin="0,0,16,0"
                Padding="14"
                CornerRadius="20"
                Background="#F9FFFFFF"
                BorderBrush="#22000000"
                BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14"
                                  ShadowDepth="2"
                                  Opacity="0.14"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Search area -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Search manufacturer or model"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF44546A"
                               Margin="0,0,0,6"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="CreateOrderSearchBox"
                                 Grid.Column="0"
                                 Height="34"
                                 Margin="0,0,10,0"
                                 Padding="8,4"
                                 VerticalContentAlignment="Center"
                                 KeyDown="CreateOrderSearchBox_KeyDown"/>

                                <Button Content="Search"
                                Grid.Column="1"
                                Height="34"
                                Margin="0,0,10,0"
                                Style="{StaticResource MenuButton}"
                                Click="SearchCreateOrder_Click"/>

                                <Button Content="Show All"
                                Grid.Column="2"
                                Height="34"
                                Style="{StaticResource MenuButton}"
                                Click="ShowAllCreateOrder_Click"/>
                            </Grid>
                        </StackPanel>

                        <!-- Phones grid -->
                        <DataGrid x:Name="CreateOrderPhonesGrid"
                                  Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  SelectionChanged="OrderInputChanged"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">

                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#FFEAF4FF"/>
                                    <Setter Property="Foreground" Value="#FF1E3A8A"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderBrush" Value="#FFD0D7DE"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFEEF8FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#FFE6F2FF"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Phone ID"
                                            Binding="{Binding PhoneID}"
                                            Width="70"/>

                                <DataGridTextColumn Header="Manufacturer"
                                            Binding="{Binding Manufacturer}"
                                            Width="1.2*"/>

                                <DataGridTextColumn Header="Model"
                                            Binding="{Binding Model}"
                                            Width="1.7*"/>

                                <DataGridTextColumn Header="Storage"
                                            Binding="{Binding Storage, StringFormat={}{0} GB}"
                                            Width="80"/>

                                <DataGridTextColumn Header="Year"
                                            Binding="{Binding ReleaseYear}"
                                            Width="80"/>

                                <DataGridTextColumn Header="Price"
                                            Binding="{Binding Price, StringFormat=£{0:F2}}"
                                            Width="90"/>

                                <DataGridTextColumn Header="Stock"
                                            Binding="{Binding Stock}"
                                            Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- RIGHT SIDE -->
                <Border Grid.Column="1"
        Padding="14"
        CornerRadius="20"
        Background="#F9FFFFFF"
        BorderBrush="#22000000"
        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14"
                          ShadowDepth="2"
                          Opacity="0.14"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Order Details"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#FF1E3A8A"
                   Margin="0,0,0,12"/>

                        <!-- FORM AREA -->
                        <Grid Grid.Row="1" Grid.RowSpan="5">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Quantity"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBox x:Name="QuantityTextBox"
                                     Grid.Row="1"
                                     Height="24"
                                     Padding="8,4"
                                     Margin="0,0,0,10"
                                     VerticalContentAlignment="Center"
                                     TextChanged="OrderInputChanged"
                                     MaxLength="3"
                                     PreviewTextInput="NumbersOnly"/>

                            <TextBlock Grid.Row="2"
                                       Text="Client Type"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>

                            <ComboBox x:Name="ClientTypeBox"
                                      Grid.Row="3"
                                      Height="24"
                                      Margin="0,0,0,10"
                                      MaxDropDownHeight="120"
                                      SelectionChanged="ClientTypeBox_SelectionChanged">
                                <ComboBoxItem Content="Customer"/>
                                <ComboBoxItem Content="Company"/>
                            </ComboBox>

                            <TextBlock Grid.Row="4"
                                       Text="Contract Type"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <ComboBox x:Name="ContractTypeBox"
                                      Grid.Row="5"
                                      Height="24"
                                      Margin="0,0,0,10"
                                      MaxDropDownHeight="120"
                                  SelectionChanged="ContractTypeBox_SelectionChanged">
                                <ComboBoxItem Content="SIM-Free"/>
                                <ComboBoxItem Content="Phone + SIM Package"/>
                                <ComboBoxItem Content="Hire Contract"/>
                            </ComboBox>

                            <TextBlock x:Name="PlanTypeLabel"
                                       Grid.Row="6"
                                       Text="Plan Type"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"
                                       Visibility="Collapsed"/>
                            <ComboBox x:Name="PlanTypeBox"
                                      Grid.Row="7"
                                      Height="24"
                                      Margin="0,0,0,10"
                                      MaxDropDownHeight="120"
                                      Visibility="Collapsed"
                                      SelectionChanged="OrderInputChanged">
                                <ComboBoxItem Content="Standard"/>
                                <ComboBoxItem Content="Premium"/>
                            </ComboBox>

                            <TextBlock x:Name="DurationLabel"
                                       Grid.Row="8"
                                       Text="Duration"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"
                                       Visibility="Collapsed"/>
                            <ComboBox x:Name="DurationBox"
                                      Grid.Row="9"
                                      Height="24"
                                      Margin="0,0,0,0"
                                      MaxDropDownHeight="120"
                                      Visibility="Collapsed"
                                      SelectionChanged="OrderInputChanged"/>
                        </Grid>

                        <!-- SUMMARY -->
                        <Border Grid.Row="7"
                                Background="#FFF8FBFF"
                                BorderBrush="#FFD9E2EC"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12"
                                MinHeight="150">
                            <StackPanel>
                                <TextBlock Text="Order Summary"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Foreground="#FF1F2937"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="Phone Details"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#FF1E3A8A"/>
                                <TextBlock x:Name="PhoneDetailsText"
                                           FontWeight="SemiBold"
                                           Text="-"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,12"
                                           Foreground="#FF334155"/>

                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- LEFT: Total -->
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Contract Price"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Foreground="#FF1E3A8A"/>

                                        <TextBlock x:Name="TotalPriceText"
                                                   Text="£0.00"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="#FF111827"/>
                                    </StackPanel>

                                    <!-- RIGHT: Monthly -->
                                    <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                        <TextBlock Text="Monthly"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FF1E3A8A"/>

                                        <TextBlock x:Name="MonthlyCostText"
                                                   Text="£0.00"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FF334155"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bottom buttons -->
            <Grid Grid.Row="2" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Back"
                        Width="110"
                        Height="36"
                        HorizontalAlignment="Left"
                        Style="{StaticResource ExitMenuButton}"
                        Click="BackFromCreateOrder_Click"/>

                <Button Grid.Column="1"
                        Content="Continue"
                        Width="130"
                        Height="36"
                        HorizontalAlignment="Right"
                        Style="{StaticResource MenuButton}"
                        Click="ContinueOrder_Click"/>
            </Grid>
        </Grid>


        <!-- 3. PROCESS ORDER PANEL -->
        <Grid x:Name="ProcessOrdersPanel" Visibility="Collapsed" Margin="16,16,16,16" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Process Orders"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#FF1E3A8A"
                       Margin="0,0,0,14"/>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.75*"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE -->
                <Border Grid.Column="0"
                        Margin="0,0,16,0"
                        Padding="14"
                        CornerRadius="20"
                        Background="#F9FFFFFF"
                        BorderBrush="#22000000"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14"
                                          ShadowDepth="2"
                                          Opacity="0.14"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="271*"/>
                            <RowDefinition Height="200*"/>
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="PendingOrdersGrid"
                                  Grid.Row="0"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionChanged="PendingOrdersGrid_SelectionChanged"
                                  Margin="0,0,0,3"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">

                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#FFEAF4FF"/>
                                    <Setter Property="Foreground" Value="#FF1E3A8A"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderBrush" Value="#FFD0D7DE"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFEEF8FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#FFE6F2FF"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Client"
                                            Binding="{Binding ClientName}"
                                            Width="*"/>

                                <DataGridTextColumn Header="Phone"
                                            Binding="{Binding PhoneName}"
                                            Width="1.7*"/>

                                <DataGridTextColumn Header="Qty"
                                            Binding="{Binding Quantity}"
                                            Width="50"/>

                                <DataGridTextColumn Header="Contract"
                                            Binding="{Binding ContractType}"
                                            Width="145"/>

                                <DataGridTextColumn Header="Total"
                                            Binding="{Binding TotalPrice, StringFormat=£{0:F2}}"
                                            Width="85"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border
                        Background="#FFF8FBFF"
                        BorderBrush="#FFD9E2EC"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="10" Margin="0,10,299,0" Grid.Row="1">
                            <StackPanel>
                                <TextBlock Text="Selected Order Summary"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Foreground="#FF1F2937"
                                   Margin="0,0,0,8"/>

                                <TextBlock x:Name="ProcessSummaryText"
                                   Text="Select an order to view details."
                                    FontSize="14"
                                   TextWrapping="Wrap"
                                   Foreground="#FF334155"/>
                            </StackPanel>
                        </Border>

                        <!-- Final Payment Summary -->
                        <Border Padding="10"
                                CornerRadius="16"
                                Background="#FFF8FBFF"
                                BorderBrush="#FFD9E2EC"
                                BorderThickness="1" Margin="275,10,0,0" Grid.Row="1">
                            <StackPanel>
                                <TextBlock Text="Final Payment Summary"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Foreground="#FF1F2937"
                                           Margin="0,0,0,10"/>

                                <TextBlock x:Name="BasePriceText"
                                           Text="Base Price: £0.00"
                                           Margin="0,0,0,5"
                                           Foreground="#FF334155"/>

                                <TextBlock x:Name="DiscountAmountText"
                                           Text="Discount Amount: £0.00"
                                           Margin="0,0,0,6"
                                           Foreground="#FF334155"/>

                                <TextBlock x:Name="TotalPayableText"
                                           Text="Total Payable: £0.00"
                                           FontWeight="Bold"
                                           FontSize="15"
                                           Foreground="#FF111827"/>
                                <TextBlock x:Name="MonthlyInstallmentsLabel"
                                           Text="Monthly Instalments:"
                                           FontWeight="SemiBold"
                                           Foreground="#FF1E3A8A"
                                           Margin="0,10,0,2"
                                           Visibility="Collapsed"/>

                                <TextBlock x:Name="MonthlyInstallmentsText"
                                           Text="£0.00"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#FF334155"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- RIGHT SIDE -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Staff Information -->
                        <Border Padding="10"
                                CornerRadius="16"
                                Background="#F9FFFFFF"
                                BorderBrush="#22000000"
                                BorderThickness="1"
                                Margin="0,0,0,10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12"
                                                  ShadowDepth="2"
                                                  Opacity="0.12"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock Text="Staff Information"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Foreground="#FF1E3A8A"
                                           Margin="0,0,0,10"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="132"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="Processed By"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               FontSize="13"
                                               FontWeight="SemiBold"/>

                                    <Border Grid.Column="1"
                                            Background="#FFF8FAFC"
                                            BorderBrush="#FFD9E2EC"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8,5">
                                        <TextBlock x:Name="ProcessedByBox"
                                                   Foreground="#FF334155"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Discount Approval -->
                        <Border Padding="10"
                                CornerRadius="16"
                                Background="#F9FFFFFF"
                                BorderBrush="#22000000"
                                BorderThickness="1"
                                Margin="0,0,0,10">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12"
                                                  ShadowDepth="2"
                                                  Opacity="0.12"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock Text="Discount Approval"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Foreground="#FF1E3A8A"
                                           Margin="0,0,0,12"/>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="132"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Apply Discount"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,6"
                                               FontSize="13"
                                               FontWeight="SemiBold"/>

                                    <ComboBox x:Name="ApplyDiscountBox"
                                              Grid.Row="0" Grid.Column="1"
                                              Height="24"
                                              FontSize="13"
                                              Padding="6,2"
                                              MaxDropDownHeight="120"
                                              Margin="0,0,0,6"
                                              SelectionChanged="ApplyDiscountBox_SelectionChanged">
                                        <ComboBoxItem Content="No"/>
                                        <ComboBoxItem Content="Yes"/>
                                    </ComboBox>

                                    <TextBlock x:Name="ManagerUsernameLabel"
                                               Grid.Row="1" Grid.Column="0"
                                               Text="Manager Username"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,6"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Visibility="Collapsed"/>

                                    <TextBox x:Name="ManagerUsernameBox"
                                             Grid.Row="1" Grid.Column="1"
                                             Height="24"
                                             FontSize="13"
                                             Padding="6,2"
                                             Margin="0,0,0,6"
                                             VerticalContentAlignment="Center"
                                             Visibility="Collapsed"/>

                                    <TextBlock x:Name="ManagerPasswordLabel"
                                               Grid.Row="2" Grid.Column="0"
                                               Text="Manager Password"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,6"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Visibility="Collapsed"/>

                                    <PasswordBox x:Name="ManagerPasswordBox"
                                                 Grid.Row="2" Grid.Column="1"
                                                 Height="24"
                                                 FontSize="13"
                                                 Margin="0,0,0,6"
                                                 Visibility="Collapsed"/>

                                    <TextBlock x:Name="DiscountPercentLabel"
                                               Grid.Row="3" Grid.Column="0"
                                               Text="Discount %"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Visibility="Collapsed"/>
                                    <TextBox x:Name="DiscountPercentBox"
                                             Grid.Row="3" Grid.Column="1"
                                             Height="24"
                                             FontSize="13"
                                             Padding="6,2"
                                             VerticalContentAlignment="Center"
                                             TextChanged="DiscountPercentBox_TextChanged"
                                             Visibility="Collapsed"/>

                                    <Button x:Name="ValidateDiscountButton"
                                            Grid.Row="4"
                                            Grid.Column="1"
                                            Content="Validate"
                                            Height="28"
                                            Margin="0,8,0,0"
                                            Style="{StaticResource MenuButton}"
                                            Visibility="Collapsed"
                                            Click="ValidateDiscountButton_Click"/>

                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Payment Details -->
                        <Border Padding="12"
                                CornerRadius="16"
                                Background="#F9FFFFFF"
                                BorderBrush="#22000000"
                                BorderThickness="1"
                                Margin="0,0,0,0">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12"
                                          ShadowDepth="2"
                                          Opacity="0.12"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock Text="Payment Details"
                                   FontWeight="Bold"
                                   FontSize="16"
                                   Foreground="#FF1E3A8A"
                                   Margin="0,0,0,9"/>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="132"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Payment Method"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,6"
                                               FontSize="13"
                                               FontWeight="SemiBold"/>
                                    <ComboBox x:Name="PaymentMethodBox"
                                              Grid.Row="0" Grid.Column="1"
                                              Height="24"
                                              FontSize="13"
                                              Padding="6,2"
                                              MaxDropDownHeight="120"
                                              Margin="0,0,0,6"
                                              SelectionChanged="PaymentMethodBox_SelectionChanged">
                                        <ComboBoxItem Content="CASH"/>
                                        <ComboBoxItem Content="CARD"/>
                                    </ComboBox>

                                    <TextBlock x:Name="SortCodeLabel"
                                               Grid.Row="1" Grid.Column="0"
                                               Text="Sort Code"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,6"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Visibility="Collapsed"/>
                                    <TextBox x:Name="SortCodeBox"
                                             Grid.Row="1" Grid.Column="1"
                                             MaxLength="8"
                                             TextChanged="SortCodeBox_TextChanged"
                                             PreviewTextInput="NumbersOnly"
                                             Height="24"
                                             FontSize="13"
                                             Padding="6,2"
                                             Margin="0,0,0,6"
                                             VerticalContentAlignment="Center"
                                             Visibility="Collapsed"/>

                                    <TextBlock x:Name="AccountNumberLabel"
                                               Grid.Row="2" Grid.Column="0"
                                               Text="Account Number"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,6"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Visibility="Collapsed"/>
                                    <TextBox x:Name="AccountNumberBox"
                                             MaxLength="8"
                                             PreviewTextInput="NumbersOnly"
                                             Grid.Row="2" Grid.Column="1"
                                             Height="24"
                                             FontSize="13"
                                             Padding="6,2"
                                             Margin="0,0,0,6"
                                             VerticalContentAlignment="Center"
                                             Visibility="Collapsed"/>

                                    <TextBlock x:Name="PaymentOptionLabel"
                                               Grid.Row="3" Grid.Column="0"
                                               Text="Payment Option"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Visibility="Collapsed"/>
                                    <ComboBox x:Name="PaymentOptionBox"
                                              Grid.Row="3" Grid.Column="1"
                                              Height="24"
                                              FontSize="13"
                                              Padding="6,2"
                                              MaxDropDownHeight="120"
                                              Visibility="Collapsed"
                                              SelectionChanged="PaymentOptionBox_SelectionChanged">
                                        <ComboBoxItem Content="Full Payment"/>
                                        <ComboBoxItem Content="Monthly Instalments"/>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Bottom Buttons -->
            <Grid Grid.Row="2" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                Content="Back"
                Width="110"
                Height="36"
                HorizontalAlignment="Left"
                Style="{StaticResource ExitMenuButton}"
                Click="BackFromProcessOrders_Click"/>

                <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
                    <Button Content="Delete Order"
                    Width="130"
                    Height="36"
                    Margin="0,0,10,0"
                    Style="{StaticResource ExitMenuButton}"
                    Click="DeleteOrder_Click"/>

                    <Button Content="Process Order"
                    Width="140"
                    Height="36"
                    Style="{StaticResource MenuButton}"
                    Click="ProcessSelectedOrder_Click"/>
                </StackPanel>
            </Grid>
        </Grid>


        <!-- 4. UPDATE INVENTORY PANEL -->
        <Grid x:Name="InventoryPanel" Visibility="Collapsed" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text=" Inventory Management"
               FontSize="28"
               FontWeight="Bold"
               Foreground="#FF1E3A8A"
               Margin="0,0,0,14"/>

            <!-- Main content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE -->
                <Border Grid.Column="0"
                Margin="0,0,16,0"
                Padding="14"
                CornerRadius="20"
                Background="#F9FFFFFF"
                BorderBrush="#22000000"
                BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14"
                                  ShadowDepth="2"
                                  Opacity="0.14"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Search area -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="Search manufacturer or model"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#FF44546A"
                               Margin="0,0,0,6"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="InventorySearchBox"
                                 Grid.Column="0"
                                 Height="34"
                                 Margin="0,0,10,0"
                                 Padding="8,4"
                                 VerticalContentAlignment="Center"
                                 KeyDown="InventorySearchBox_KeyDown"/>

                                <Button Content="Search"
                                Grid.Column="1"
                                Height="34"
                                Margin="0,0,10,0"
                                Style="{StaticResource MenuButton}"
                                Click="SearchInventory_Click"/>

                                <Button Content="Show All"
                                Grid.Column="2"
                                Height="34"
                                Style="{StaticResource MenuButton}"
                                Click="ShowAllInventory_Click"/>
                            </Grid>
                        </StackPanel>

                        <!-- Inventory grid -->
                        <DataGrid x:Name="InventoryPhonesGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="InventoryPhonesGrid_SelectionChanged"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          RowHeaderWidth="0"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">

                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#FFEAF4FF"/>
                                    <Setter Property="Foreground" Value="#FF1E3A8A"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="BorderBrush" Value="#FFD0D7DE"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="Padding" Value="8,6"/>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#FFEEF8FF"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#FFE6F2FF"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Phone ID"
                                            Binding="{Binding PhoneID}"
                                            Width="70"/>

                                <DataGridTextColumn Header="Manufacturer"
                                            Binding="{Binding Manufacturer}"
                                            Width="1.2*"/>

                                <DataGridTextColumn Header="Model"
                                            Binding="{Binding Model}"
                                            Width="1.7*"/>

                                <DataGridTextColumn Header="Storage"
                                            Binding="{Binding Storage, StringFormat={}{0} GB}"
                                            Width="80"/>

                                <DataGridTextColumn Header="Year"
                                            Binding="{Binding ReleaseYear}"
                                            Width="80"/>

                                <DataGridTextColumn Header="Price"
                                            Binding="{Binding Price, StringFormat=£{0:F2}}"
                                            Width="90"/>

                                <DataGridTextColumn Header="Stock"
                                            Binding="{Binding Stock}"
                                            Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- RIGHT SIDE -->
                <Border Grid.Column="1"
                Padding="14"
                CornerRadius="20"
                Background="#F9FFFFFF"
                BorderBrush="#22000000"
                BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14"
                                  ShadowDepth="2"
                                  Opacity="0.14"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>



                        <TextBlock Grid.Row="1"
                           Text="Choose Inventory Action"
                           FontSize="20"
                           Foreground="#FF1E3A8A"
                           FontWeight="Bold"
                           Margin="0,0,0,12"/>
                        <ComboBox x:Name="InventoryActionBox"
                          Grid.Row="1"
                          Margin="0,30,0,10"
                          Height="24"
                          SelectionChanged="InventoryActionBox_SelectionChanged">
                            <ComboBoxItem Content="Add Phone"/>
                            <ComboBoxItem Content="Remove Phone"/>
                            <ComboBoxItem Content="Update Stock"/>
                            <ComboBoxItem Content="Change Price"/>
                        </ComboBox>

                        <TextBlock Grid.Row="2"
                           x:Name="InvManufacturerLabel"
                           Text="Manufacturer"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>
                        <TextBox x:Name="InvManufacturerBox"
                         Grid.Row="2"
                         Margin="0,24,0,10"
                         Height="24"
                         Padding="8,4"
                         VerticalContentAlignment="Center"/>

                        <TextBlock Grid.Row="3"
                           x:Name="InvModelLabel"
                           Text="Model"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>
                        <TextBox x:Name="InvModelBox"
                         Grid.Row="3"
                         Margin="0,24,0,10"
                         Height="24"
                         Padding="8,4"
                         VerticalContentAlignment="Center"/>

                        <TextBlock Grid.Row="4"
                           x:Name="InvStorageLabel"
                           Text="Storage (GB)"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>
                        <ComboBox x:Name="InvStorageBox"
                          Grid.Row="4"
                          Margin="0,24,0,10"
                          Height="24"
                          SelectedIndex="2">
                            <ComboBoxItem Content="32"/>
                            <ComboBoxItem Content="64"/>
                            <ComboBoxItem Content="128"/>
                            <ComboBoxItem Content="256"/>
                            <ComboBoxItem Content="512"/>
                            <ComboBoxItem Content="1024"/>
                            <ComboBoxItem Content="2048"/>
                            <ComboBoxItem Content="4096"/>
                        </ComboBox>

                        <TextBlock Grid.Row="5"
                           x:Name="InvReleaseYearLabel"
                           Text="Release Year"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>
                        <TextBox x:Name="InvReleaseYearBox"
                         Grid.Row="5"
                         Margin="0,24,0,10"
                         Height="24"
                         Padding="8,4"
                         VerticalContentAlignment="Center"
                         MaxLength="4"
                         PreviewTextInput="NumbersOnly"/>

                        <TextBlock Grid.Row="6"
                           x:Name="InvPriceLabel"
                           Text="Current Price"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"
                           Visibility="Collapsed"/>
                        <TextBox x:Name="InvPriceBox"
                         Grid.Row="6"
                         Margin="0,24,0,10"
                         Height="24"
                         Padding="8,4"
                         VerticalContentAlignment="Center"
                         MaxLength="8"
                         Visibility="Collapsed"
                         PreviewTextInput="PriceInput"/>

                        <TextBlock Grid.Row="7"
                           x:Name="InvCurrentPriceLabel"
                           Text="Current Price"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"
                           Visibility="Collapsed"/>
                        <TextBox x:Name="InvCurrentPriceBox"
                         Grid.Row="7"
                         Margin="0,24,0,10"
                         Height="24"
                         Padding="8,4"
                         VerticalContentAlignment="Center"
                         IsReadOnly="True"
                         Visibility="Collapsed"/>

                        <TextBlock Grid.Row="8"
                           x:Name="InvNewPriceLabel"
                           Text="Enter New Price"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"
                           Visibility="Collapsed"/>
                        <TextBox x:Name="InvNewPriceBox"
                         Grid.Row="8"
                         Margin="0,24,0,12"
                         Height="24"
                         Padding="8,4"
                         VerticalContentAlignment="Center"
                         MaxLength="7"
                         Visibility="Collapsed"
                         PreviewTextInput="PriceInput"/>

                        <TextBlock Grid.Row="9"
                           x:Name="InvInitialStockLabel"
                           Text="Enter Initial Stock"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"
                           Visibility="Collapsed"/>
                        <TextBox x:Name="InvInitialStockBox"
                         Grid.Row="9"
                         Margin="0,24,0,12"
                         Height="24"
                         Padding="8,4"
                         VerticalContentAlignment="Center"
                         MaxLength="3"
                         Visibility="Collapsed"
                         PreviewTextInput="NumbersOnly"/>

                        <StackPanel Grid.Row="10">
                            <TextBlock x:Name="InvOldStockLabel"
                                       Text="Old Stock"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"
                                       Visibility="Collapsed"/>
                            <TextBox x:Name="InvOldStockBox"
                                     Margin="0,0,0,12"
                                     Height="24"
                                     Padding="8,4"
                                     VerticalContentAlignment="Center"
                                     IsReadOnly="True"
                                     Visibility="Collapsed"/>

                            <TextBlock x:Name="InvNewStockLabel"
                                       Text="Enter New Stock"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,5"
                                       Visibility="Collapsed"/>
                            <TextBox x:Name="InvNewStockBox"
                                     Margin="0,0,0,12"
                                     Height="24"
                                     Padding="8,4"
                                     VerticalContentAlignment="Center"
                                     MaxLength="3"
                                     Visibility="Collapsed"
                                     PreviewTextInput="NumbersOnly"/>

                            <TextBlock x:Name="InvSelectedPhoneLabel"
                                       Text="Selected phone: none"
                                       TextWrapping="Wrap"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#FF334155"
                                       Margin="0,8,0,10"
                                       Visibility="Collapsed"/>

                            <Button x:Name="InventoryActionButton"
                                    Content="Apply"
                                    Height="36"
                                    Style="{StaticResource MenuButton}"
                                    Click="InventoryActionButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bottom buttons -->
            <Grid Grid.Row="2" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                Content="Back"
                Width="110"
                Height="36"
                HorizontalAlignment="Left"
                Style="{StaticResource ExitMenuButton}"
                Click="BackFromInventory_Click"/>
            </Grid>
        </Grid>

        <!-- 5. VIEW TRANSACTIONS PANEL -->
        <Grid x:Name="TransactionsPanel" Visibility="Collapsed" Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="View Transactions"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#FF1E3A8A"
                       Margin="0,0,0,14"/>

            <!-- Main content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT SIDE: ACTIVE CONTENT -->
                <Border Grid.Column="0"
                        Margin="0,0,16,0"
                        Padding="14"
                        CornerRadius="20"
                        Background="#F9FFFFFF"
                        BorderBrush="#22000000"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14"
                                          ShadowDepth="2"
                                          Opacity="0.14"/>
                    </Border.Effect>

                    <Grid>
                        <!-- WELCOME PANEL -->
                        <Grid x:Name="TransactionsWelcomePanel" Visibility="Visible">
                            <TextBlock Text="Select a tab on the right to view transaction information."
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FF475569"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"/>
                        </Grid>

                        <!-- SHOP BALANCE -->
                        <Grid x:Name="ShopBalancePanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            

                            <TextBlock Text="Shop Balance Summary"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#FF1E3A8A"
                                       Margin="0,0,0,14"/>

                            <UniformGrid Grid.Row="1" Columns="2">
                                <Border Margin="0,0,10,10"
                                        Padding="12"
                                        CornerRadius="14"
                                        Background="#FFF8FBFF"
                                        BorderBrush="#FFD9E2EC"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Current Phones in Stock"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FF1E3A8A"/>
                                        <TextBlock x:Name="StockUnitsText"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#FF111827"/>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        CornerRadius="14"
                                        Background="#FFF8FBFF"
                                        BorderBrush="#FFD9E2EC"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Current Stock Value"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Foreground="#FF1E3A8A"/>
                                        <TextBlock x:Name="StockValueText"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#FF111827"/>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,0,10,10"
                                        Padding="12"
                                        CornerRadius="14"
                                        Background="#FFF8FBFF"
                                        BorderBrush="#FFD9E2EC"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Total Phones Sold"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Foreground="#FF1E3A8A"/>
                                        <TextBlock x:Name="PhonesSoldText"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#FF111827"/>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,0,0,10"
                                        Padding="12"
                                        CornerRadius="14"
                                        Background="#FFF8FBFF"
                                        BorderBrush="#FFD9E2EC"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Total Revenue Earned"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Foreground="#FF1E3A8A"/>
                                        <TextBlock x:Name="RevenueText"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#FF111827"/>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,0,10,0"
                                        Padding="12"
                                        CornerRadius="14"
                                        Background="#FFF8FBFF"
                                        BorderBrush="#FFD9E2EC"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Total Discount Applied"
                                                   FontWeight="SemiBold"
                                                   FontSize="16"
                                                   Foreground="#FF1E3A8A"/>
                                        <TextBlock x:Name="DiscountAppliedText"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="#FF111827"/>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,0,0,0"
                                        Padding="12"
                                        CornerRadius="14"
                                        Background="#FFEFF6FF"
                                        BorderBrush="#FFBFD7F2"
                                        BorderThickness="1.5">
                                    <StackPanel>
                                        <TextBlock Text="Total Shop Balance"
                                                   FontSize="20"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FF1E3A8A"/>
                                        <TextBlock x:Name="TotalBalanceText"
                                                   FontSize="26"
                                                   FontWeight="Bold"
                                                   Foreground="#FF111827"/>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </Grid>

                        <!-- ORDER HISTORY -->
                        <Grid x:Name="OrderHistoryPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Order History"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#FF1E3A8A"
                                       Margin="0,0,0,12"/>

                            <DataGrid x:Name="OrderHistoryGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="True"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                                
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="FontWeight" Value="Normal"/>
                                        <Setter Property="Background" Value="White"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FFEEF8FF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#FFE6F2FF"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#FFEAF4FF"/>
                                        <Setter Property="Foreground" Value="#FF1E3A8A"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                    </Style>
                                </DataGrid.Resources>
                            </DataGrid>
                        </Grid>

                        <!-- CLIENTS -->
                        <Grid x:Name="ClientsPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Clients"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#FF1E3A8A"
                                       Margin="0,0,0,12"/>

                            <DataGrid x:Name="ClientsGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="True"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#FFEAF4FF"/>
                                        <Setter Property="Foreground" Value="#FF1E3A8A"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                    </Style>
                                </DataGrid.Resources>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="FontWeight" Value="Normal"/>
                                        <Setter Property="Background" Value="White"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FFEEF8FF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#FFE6F2FF"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>

                            </DataGrid>
                        </Grid>

                        <!-- INVENTORY LOG -->
                        <Grid x:Name="InventoryLogPanel" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Inventory Log"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#FF1E3A8A"
                                       Margin="0,0,0,12"/>

                            <DataGrid x:Name="InventoryLogGrid"
                                      Grid.Row="1"
                                      AutoGenerateColumns="True"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#FFEAF4FF"/>
                                        <Setter Property="Foreground" Value="#FF1E3A8A"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Padding" Value="8,6"/>
                                    </Style>
                                </DataGrid.Resources>

                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Setter Property="FontWeight" Value="Normal"/>
                                        <Setter Property="Background" Value="White"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FFEEF8FF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#FFE6F2FF"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>

                            </DataGrid>
                        </Grid>
                    </Grid>
                </Border>

                <!-- RIGHT SIDE: TABS -->
                <Border Grid.Column="1"
                        Padding="14"
                        CornerRadius="20"
                        Background="#F9FFFFFF"
                        BorderBrush="#22000000"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="14"
                                  ShadowDepth="2"
                                  Opacity="0.14"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Transaction Tabs"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="#FF1E3A8A"
                                   Margin="0,0,0,14"/>

                        <Button Grid.Row="1"
                                Content="Shop Balance"
                                Height="40"
                                Margin="0,0,0,10"
                                Style="{StaticResource MenuButton}"
                                Click="ViewShopBalance_Click"/>

                        <Button Grid.Row="2"
                                Content="View Order History"
                                Height="40"
                                Margin="0,0,0,10"                              
                                Style="{StaticResource MenuButton}"
                                Click="ViewOrderHistory_Click"/>

                        <Button Grid.Row="3"
                                Content="View Clients"
                                Height="40"
                                Margin="0,0,0,10"
                                Style="{StaticResource MenuButton}"
                                Click="ViewClients_Click"/>

                        <StackPanel Grid.Row="4" VerticalAlignment="Top">
                            <Button Content="View Inventory Log"
                                    Height="40"
                                    Margin="0,0,0,10"
                                    Style="{StaticResource MenuButton}"
                                    Click="ViewInventoryLog_Click"/>

                            <TextBlock Text="Choose a tab to load the relevant records into the main grid area."
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Foreground="#FF475569"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Bottom buttons -->
            <Grid Grid.Row="2" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Back"
                        Width="110"
                        Height="36"
                        HorizontalAlignment="Left"
                        Style="{StaticResource ExitMenuButton}"
                        Click="BackFromTransactions_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>