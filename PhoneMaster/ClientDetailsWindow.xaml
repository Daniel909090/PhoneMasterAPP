<Window x:Class="PhoneMaster.GUI.ClientDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Client Details"
        Height="450"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="ClientTypeTitle"
                       Text="Client Details"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <TextBlock Text="Name"/>
            <TextBox x:Name="NameBox" Margin="0,0,0,8"/>

            <TextBlock Text="Email"/>
            <TextBox x:Name="EmailBox" Margin="0,0,0,8"/>

            <TextBlock Text="Contact Phone"/>
            <TextBox x:Name="PhoneBox" Margin="0,0,0,8"/>

            <TextBlock Text="Address"/>
            <TextBox x:Name="AddressBox" Margin="0,0,0,8"/>

            <TextBlock Text="Postcode"/>
            <TextBox x:Name="PostcodeBox" Margin="0,0,0,8"/>

            <TextBlock Text="Town"/>
            <TextBox x:Name="TownBox" Margin="0,0,0,8"/>

            <TextBlock x:Name="VatLabel"
                       Text="VAT Number"
                       Visibility="Collapsed"/>
            <TextBox x:Name="VatNumberBox"
                     Margin="0,0,0,8"
                     Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,8,0,7" Width="294">
            <Button Content="Cancel"
                    Width="100"
                    Margin="5"
                    Click="Cancel_Click"/>
            <Button Content="Send Order to Staff"
                    Width="141"
                    Click="Save_Click" Height="20" Background="#FF9BE418" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>